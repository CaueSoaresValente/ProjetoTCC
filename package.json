    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^9.39.2",
    "eslint-config-vuetify": "^4.3.4",
    "npm-run-all2": "^8.0.4",
    "sass-embedded": "^1.97.1",
    "tailwindcss": "^4.1.18",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
