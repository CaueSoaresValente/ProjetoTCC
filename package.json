{
  "name": "front-tcc",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "dev": "vite",
    "dev:backend": "tsx --tsconfig tsconfig.backend.json --watch src/backend/index.ts",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "mcp": "ruler apply",
    "mcp:revert": "ruler revert",
    "build:backend": "tsc --project tsconfig.backend.json",
    "start:backend": "node dist-backend/index.js"
  },
