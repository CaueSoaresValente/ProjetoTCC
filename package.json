    "@vuelidate/core": "^2.0.3",
    "@vuelidate/validators": "^2.0.4",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.28",
    "vue": "^3.5.26",
    "vue-router": "^5.0.3",
    "vuetify": "^4.0.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
